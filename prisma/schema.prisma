
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  createdAt   DateTime @default(now())
  responses   AuditResponse[]
  report      AuditReport?
}

model AuditResponse {
  id        String   @id @default(cuid())
  clientId  String
  domain    String   // e.g. "professional_work", "communication", etc.
  answers   Json     // { question: string, answer: string }[]
  client    Client   @relation(fields: [clientId], references: [id])
}

model AuditReport {
  id              String   @id @default(cuid())
  clientId        String   @unique
  automationMap   Json     // Full structured output from Claude
  quickWins       Json     // Top 10 wins
  implementationGuide Json
  generatedAt     DateTime @default(now())
  client          Client   @relation(fields: [clientId], references: [id])
}
